{
  "functions": {
    "src/app/api/scraper/route.ts":                    { "maxDuration": 300 },
    "src/app/api/maintenance/route.ts":                { "maxDuration": 120 },
    "src/app/api/cron/alertas/route.ts":               { "maxDuration": 60 },
    "src/app/api/cron/scraper-pisoscom/route.ts":      { "maxDuration": 180 },
    "src/app/api/cron/scraper-solvia/route.ts":        { "maxDuration": 120 },
    "src/app/api/gestoria/checkout/route.ts":          { "maxDuration": 30 },
    "src/app/api/stripe/checkout/route.ts":            { "maxDuration": 30 },
    "src/app/api/cron/generate-descriptions/route.ts": { "maxDuration": 60 }
  },
  "rewrites": [],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(gestoria|vender-casa|agencias|publicar-anuncio|contacto|seguridad|blog|pisos)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/:ciudad/(alquiler-particulares|alquiler-sin-agencia|contrato-alquiler|contrato-arras|vender-piso|pisos)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" }
      ]
    }
  ],
  "crons": []
}

